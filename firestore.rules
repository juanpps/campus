rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar: Verifica si está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Función auxiliar: Obtiene el rol del usuario desde su token o userdoc
    function getRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    // Colección Central: usuarios
    match /usuarios/{userId} {
      // El usuario puede leerse a sí mismo, un admin puede leer a todos
      allow read: if isAuth() && (request.auth.uid == userId || getRole() in ['admin', 'superadmin', 'tutor']);
      allow write: if isAuth() && (request.auth.uid == userId || getRole() in ['admin', 'superadmin']);
    }

    // OBLIGATORIO: Regla estricta para simulacros
    match /simulacros/{simulacroId} {
      allow read: if isAuth();
      allow write: if isAuth() && getRole() in ['admin', 'superadmin', 'tutor'];
      
      // LA CORONA DEL SISTEMA: Sub-colección de claves
      // BLOQUEADA AL CLIENTE SIEMPRE.
      match /claves/{document=**} {
        allow read, write: if false; 
        // Solo el backend con Admin SDK puede leer la clave de respuestas para calificar.
      }
    }
    
    // Colecciones genéricas
    match /materias/{document=**} {
      allow read: if isAuth();
      allow write: if isAuth() && getRole() in ['admin', 'superadmin'];
    }

    match /clases/{document=**} {
      allow read: if isAuth();
      allow write: if isAuth() && getRole() in ['admin', 'superadmin', 'tutor'];
    }

    match /resultados/{document=**} {
      // Un estudiante solo lee sus propios resultados. Tutores y Admins todos.
      allow read: if isAuth() && (resource.data.estudiante_id == request.auth.uid || getRole() in ['admin', 'superadmin', 'tutor']);
      allow write: if false; // Solo backend en calificación automática
    }
  }
}
